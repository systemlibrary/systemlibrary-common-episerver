<?xml version = "1.0" ?>
<package xmlns="http://schemas.microsoft.com/packaging/2010/07/nuspec.xsd">
	<metadata>
		<id>SystemLibrary.Common.Episerver</id>

		<version>6.4.0.1</version>

		<authors>System Library</authors>

		<owners>System Library</owners>

		<projectUrl>https://www.systemlibrary.com/#SystemLibraryCommonEpiserver</projectUrl>

		<license type="expression">Apache-2.0</license>

		<icon>nuget-icon.png</icon>

		<requireLicenseAcceptance>false</requireLicenseAcceptance>

		<releaseNotes>
			Latest version:
			https://github.com/systemlibrary/systemlibrary-common-episerver#latest-version
		</releaseNotes>

		<description>
Library with classes, methods and dijits for every .NET &gt;= 6 episerver web application
https://github.com/systemlibrary/systemlibrary-common-episerver/#Description

Installation
https://systemlibrary.github.io/systemlibrary-common-episerver/Install.html

Documentation with sample code
https://systemlibrary.github.io/systemlibrary-common-episerver/
		</description>

		<copyright>Copyright © System Library</copyright>

		<tags>C# .NET 6.0 Episerver Optimizely Library</tags>

		<readme>docs\readme.md</readme>
		
		<dependencies>
			<dependency id="EPiServer.Framework" version="12.11.0" />
			<dependency id="EPiServer.Hosting" version="12.11.0" />
			<dependency id="EPiServer.CMS.AspNetCore.Routing" version="12.11.0" />
			<dependency id="EPiServer.CMS.UI.AspNetIdentity" version="12.15.0" />
			<dependency id="SystemLibrary.Common.Web" version="6.3.1.6" />
		</dependencies>
	</metadata>

	<files>
		<file src="nuget-icon.png" target="" />
		<file src="..\..\readme.md" target="docs\" />
		<file src="..\..\assets\images\" target="docs\assets\images\" />
	</files>
</package>
<!-- Command: nuget pack SystemLibrary.Common.Net.csproj -p Configuration=Release -->
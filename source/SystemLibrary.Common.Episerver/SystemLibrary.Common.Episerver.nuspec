<?xml version = "1.0" ?>
<package xmlns="http://schemas.microsoft.com/packaging/2010/07/nuspec.xsd">
	<metadata>
		<id>SystemLibrary.Common.Episerver</id>

		<version>3.0.0.2</version>

		<authors>System Library</authors>

		<owners>System Library</owners>

		<projectUrl>https://systemlibrary.com/package/SystemLibrary.Common.Episerver</projectUrl>

		<license type="expression">Apache-2.0</license>

		<icon>nuget-icon.png</icon>

		<requireLicenseAcceptance>false</requireLicenseAcceptance>

		<releaseNotes>
			Latest version:
			https://github.com/systemlibrary/systemlibrary-common-episerver#latest-version
		</releaseNotes>

		<description>
			A common library for all .NET &gt;= 6 episerver applications - various reusable extensions and classes

			Selling points:
			* Extensions for XhtmlString, ContentReference, ContentArea, ...
			* Initialize your application through two methods for Episerver 12, in &gt;= .NET 6: app.CommonEpiserverInitialization(); and services.CommonEpiserverServices&lt;CurrentUser&gt;(options);
			* A log builder which builds a string with all needed information about current error and request, which you control where to log to (slack, cloud watch, sentry, firebase, ...)
			* Cache class, with option to add an additional predicate, and control cache for Cms Users with a bool
			* Contains a 'CurrentUser' that you can either inherit or just inject yourself in any service/controller
			* Contains Enum attributes, ContentIcon from FontAwesome, ColorPicker, and much, much more!

			Documentation:
			https://systemlibrary.github.io/systemlibrary-common-episerver/

			Source code:
			https://github.com/systemlibrary/systemlibrary-common-episerver/
		</description>

		<copyright>Copyright © System Library</copyright>

		<tags>C# .NET 6.0 Episerver Optimizely Library</tags>

		<dependencies>
			<dependency id="EPiServer.Hosting" version="12.8.0" />
			<dependency id="EPiServer.CMS.AspNetCore.Routing" version="12.8.0" />
			<dependency id="EPiServer.CMS.UI.AspNetIdentity" version="12.8.0" />
			<dependency id="Microsoft.AspNetCore.Rewrite" version="2.2.0" />
			<dependency id="Microsoft.Extensions.FileProviders.Abstractions" version="6.0.0" />
			<dependency id="System.Security.Cryptography.Xml" version="6.0.0" />
			<dependency id="SystemLibrary.Common.Web" version="3.2.0.1" />
			<dependency id="SystemLibrary.Common.Net" version="3.0.0.2" />
		</dependencies>
	</metadata>

	<files>
		<file src="nuget-icon.png" target="" />
	</files>
</package>
<!-- Command: nuget pack SystemLibrary.Common.Net.csproj -p Configuration=Release -->
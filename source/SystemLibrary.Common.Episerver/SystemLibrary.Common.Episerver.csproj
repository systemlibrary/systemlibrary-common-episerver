<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net6.0</TargetFramework>
		<Configurations>Release</Configurations>
		<LangVersion>latest</LangVersion>
	</PropertyGroup>

	<ItemGroup>
		<None Remove="Attributes\ContentIconAttribute\FontAwesome\Css\fontawesome-bundled.min.css" />
		<None Remove="Attributes\ContentIconAttribute\FontAwesome\WebFonts\fa-brands-400.woff2" />
		<None Remove="Attributes\ContentIconAttribute\FontAwesome\WebFonts\fa-regular-400.woff2" />
		<None Remove="Attributes\ContentIconAttribute\FontAwesome\WebFonts\fa-solid-900.woff2" />
	</ItemGroup>

	<ItemGroup>
		<EmbeddedResource Include="Attributes\ContentIconAttribute\FontAwesome\Css\fontawesome-bundled.min.css" />
		<EmbeddedResource Include="Attributes\ContentIconAttribute\FontAwesome\WebFonts\fa-brands-400.woff2" />
		<EmbeddedResource Include="Attributes\ContentIconAttribute\FontAwesome\WebFonts\fa-regular-400.woff2" />
		<EmbeddedResource Include="Attributes\ContentIconAttribute\FontAwesome\WebFonts\fa-solid-900.woff2" />
		<EmbeddedResource Include="Attributes\ContentIconAttribute\Icons\Regular\*.svg" />
		<EmbeddedResource Include="Attributes\ContentIconAttribute\Icons\Solid\*.svg" />
		<EmbeddedResource Include="Attributes\ContentIconAttribute\Icons\Brands\*.svg" />
	</ItemGroup>
	<ItemGroup>
		<FrameworkReference Include="Microsoft.AspNetCore.App" />
	</ItemGroup>
	<ItemGroup>
		<PackageReference Include="EPiServer.CMS.AspNetCore.Routing" Version="12.8.0" />
		<PackageReference Include="EPiServer.CMS.UI.AspNetIdentity" Version="12.8.0" />
		<PackageReference Include="EPiServer.Framework" Version="12.8.0" />
		<PackageReference Include="EPiServer.Hosting" Version="12.8.0" />
		<PackageReference Include="Microsoft.AspNet.WebApi.Core" Version="5.2.9" />
		<PackageReference Include="Microsoft.AspNetCore.Mvc.Razor.RuntimeCompilation" Version="6.0.6" />
		<PackageReference Include="Microsoft.AspNetCore.Rewrite" Version="2.2.0" />
		<PackageReference Include="Microsoft.Extensions.FileProviders.Abstractions" Version="6.0.0" />
		<PackageReference Include="System.Linq" Version="4.3.0" />
		<PackageReference Include="System.Security.Cryptography.Pkcs" Version="6.0.1" />
		<PackageReference Include="System.Security.Cryptography.Xml" Version="6.0.0" />
		<PackageReference Include="SystemLibrary.Common.Net" Version="3.0.0.1" />
		<PackageReference Include="SystemLibrary.Common.Web" Version="3.0.0.4" />
	</ItemGroup>

</Project>
